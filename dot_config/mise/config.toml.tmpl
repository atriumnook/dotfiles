[settings]
experimental = true
disable_backends = ["asdf", "vfox"]

[settings.pipx]
uvx = true

[tools]
# --- Runtimes ---
# Node.js
node = "24"
bun = "latest"
# Python
uv = "latest"

# --- CLI Tools ---
"github:rossmacarthur/sheldon" = "latest"
atuin = "latest"
chezmoi = "latest"
delta = "latest"
starship = "latest"
yazi = "latest"
zellij = "latest"

{{- if eq .chezmoi.os "linux" }}
tmux = "latest"
{{-   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# --- Provided by Omarchy (install on WSL) ---
bat = "latest"
eza = "latest"
fd = "latest"
fzf = "latest"
gh = "latest"
jq = "latest"
lazygit = "latest"
neovim = "latest"
ripgrep = "latest"
sqlite = "latest"
zoxide = "latest"
claude = "latest"
{{-   end }}
{{- end }}
