[settings]
experimental = true
disable_backends = ["asdf", "vfox"]

[settings.pipx]
uvx = true

[tools]
# --- Runtimes ---
# Node.js
node = "24"
bun = "latest"
# Python
uv = "latest"

# --- CLI Tools ---
"github:rossmacarthur/sheldon" = "latest"
atuin = "latest"
chezmoi = "latest"
delta = "latest"
starship = "latest"
yazi = "latest"
zellij = "latest"

{{- if or (.chezmoi.kernel.osrelease | lower | contains "microsoft") (eq .chezmoi.osRelease.id "debian") }}
# --- CLI Tools (WSL / Debian) ---
bat = "latest"
eza = "latest"
fd = "latest"
fzf = "latest"
jq = "latest"
lazygit = "latest"
neovim = "latest"
ripgrep = "latest"
zoxide = "latest"
{{- end }}
